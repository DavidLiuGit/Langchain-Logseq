# Logseq
LOGSEQ_JOURNAL_PATH="~/path/to/Logseq/journals"
JOURNAL_COLLECTION_OWNER_NAME="Foo"

# AWS Bedrock
BEDROCK_PROFILE=bedrock-profile
BEDROCK_IAM_ACCESS_KEY=ABCDEFGHIJK
BEDROCK_IAM_SECRET_KEY=TOPSECRETKEY

# PGVector — production upload target (used by scripts)
PGVECTOR_URL="postgresql+psycopg2://user:password@localhost:5432/prod_db"

# PGVector — isolated test DB (used by integ-tests only, must NOT point at prod)
TEST_PGVECTOR_URL="postgresql+psycopg2://user:password@localhost:5432/test_db"
